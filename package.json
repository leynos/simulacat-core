{
  "name": "@simulacrum/github-api-simulator",
  "version": "0.6.4",
  "description": "Provides common functionality to frontend app and plugins.",
  "keywords": [
    "emulation",
    "github-api",
    "integration testing",
    "mock",
    "mocking",
    "simulation"
  ],
  "bugs": {
    "url": "https://github.com/thefrontside/simulacrum/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thefrontside/simulacrum.git",
    "directory": "packages/github-api"
  },
  "bin": "bin/start.cjs",
  "files": [
    "README.md",
    "dist",
    "src",
    "schema",
    "repository-mock-data"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "bench": "vitest bench",
    "build": "tsdown",
    "generate": "graphql-codegen",
    "lint": "oxlint",
    "prepack": "pnpm run generate && pnpm run build",
    "start": "node --experimental-transform-types --watch ./example/start.ts",
    "start:bin": "node ./bin/start.js",
    "sync:schema:rest": "node --experimental-transform-types ./sync.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@faker-js/faker": "^9.3.0",
    "@graphql-tools/utils": "^10.9.1",
    "@simulacrum/foundation-simulator": "^0.6.1",
    "assert-ts": "^0.3.4",
    "express": "^5.2.1",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.15.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-resolvers": "^4.5.1",
    "@octokit/graphql": "^9.0.1",
    "@types/express": "^5.0.6"
  }
}
