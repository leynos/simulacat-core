{
  "name": "simulacat-core",
  "version": "0.6.4",
  "description": "Provides common functionality to frontend app and plugins.",
  "keywords": [
    "emulation",
    "github-api",
    "integration testing",
    "mock",
    "mocking",
    "simulation"
  ],
  "bugs": {
    "url": "https://github.com/thefrontside/simulacrum/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thefrontside/simulacrum.git",
    "directory": "packages/github-api"
  },
  "packageManager": "bun@1.3.11",
  "bin": "bin/start.cjs",
  "files": [
    "README.md",
    "dist",
    "src",
    "schema",
    "repository-mock-data"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "bench": "bun test --bench",
    "build": "tsdown",
    "check:types": "bun run generate && bunx tsc --noEmit",
    "fmt": "bunx @biomejs/biome format --write .",
    "generate": "graphql-codegen",
    "lint": "bunx @biomejs/biome lint .",
    "prepack": "bun run generate && bun run build",
    "start": "node --experimental-transform-types --watch ./example/start.ts",
    "start:bin": "node ./bin/start.cjs",
    "sync:schema:rest": "node --experimental-transform-types ./sync.ts",
    "test": "bun test --max-concurrency=1 tests",
    "test:watch": "bun test --watch tests",
    "tsc": "bun run check:types"
  },
  "dependencies": {
    "@faker-js/faker": "^9.3.0",
    "@graphql-tools/utils": "^10.9.1",
    "@simulacrum/foundation-simulator": "^0.6.1",
    "assert-ts": "^0.3.4",
    "express": "^5.2.1",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.15.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-resolvers": "^4.5.1",
    "@arethetypeswrong/core": "^0.18.2",
    "@octokit/graphql": "^9.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.11",
    "fast-check": "^4.3.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "lodash": "4.18.1"
  },
  "main": "./dist/index.cjs",
  "inlinedDependencies": {
    "starfx": "0.15.0"
  }
}
